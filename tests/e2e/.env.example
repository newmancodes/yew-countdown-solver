# E2E Test Environment Variables
# Copy this file to .env and modify as needed for local testing

# Base URL for the application under test
# Default: http://localhost:8080
BASE_URL=http://localhost:8080

# Run browser in headless mode (true/false)
# Set to false to watch tests run in a visible browser window
# Default: true
HEADLESS=true

# Timeout for solver operations in milliseconds
# Increase this if the solver takes longer on complex games
# Default: 30000 (30 seconds)
SOLVER_TIMEOUT=30000
